<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="18dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/outline"
        app:strokeWidth="1dp"
        app:contentPaddingLeft="20dp"
        app:contentPaddingRight="20dp"
        app:contentPaddingTop="20dp"
        app:contentPaddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="选择颜色"
                android:textColor="@color/on_surface"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <!-- 预览色块 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/colorPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#0B000000" />

                <TextView
                    android:id="@+id/hexLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="monospace"
                    android:text="#FF1A1A1A"
                    android:textSize="16sp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4" />
            </FrameLayout>

            <!-- Alpha 滑块 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <View
                        android:id="@+id/trackAlpha"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_gravity="center_vertical" />

                    <SeekBar
                        android:id="@+id/seekAlpha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="255"
                        android:progress="255"
                        android:progressDrawable="@android:color/transparent"
                        android:splitTrack="false"
                        android:thumb="@drawable/color_seekbar_thumb" />
                </FrameLayout>

                <TextView
                    android:id="@+id/labelAlpha"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="end"
                    android:text="255"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Red 滑块 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:gravity="center"
                    android:text="R"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <View
                        android:id="@+id/trackRed"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_gravity="center_vertical" />

                    <SeekBar
                        android:id="@+id/seekRed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="255"
                        android:progress="0"
                        android:progressDrawable="@android:color/transparent"
                        android:splitTrack="false"
                        android:thumb="@drawable/color_seekbar_thumb" />
                </FrameLayout>

                <TextView
                    android:id="@+id/labelRed"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="end"
                    android:text="0"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Green 滑块 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:gravity="center"
                    android:text="G"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <View
                        android:id="@+id/trackGreen"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_gravity="center_vertical" />

                    <SeekBar
                        android:id="@+id/seekGreen"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="255"
                        android:progress="0"
                        android:progressDrawable="@android:color/transparent"
                        android:splitTrack="false"
                        android:thumb="@drawable/color_seekbar_thumb" />
                </FrameLayout>

                <TextView
                    android:id="@+id/labelGreen"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="end"
                    android:text="0"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Blue 滑块 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:gravity="center"
                    android:text="B"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <View
                        android:id="@+id/trackBlue"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_gravity="center_vertical" />

                    <SeekBar
                        android:id="@+id/seekBlue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="255"
                        android:progress="0"
                        android:progressDrawable="@android:color/transparent"
                        android:splitTrack="false"
                        android:thumb="@drawable/color_seekbar_thumb" />
                </FrameLayout>

                <TextView
                    android:id="@+id/labelBlue"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="end"
                    android:text="0"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:background="@color/outline" />

            <!-- 按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnDefault"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="60dp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="默认"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip_button" />

                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:minWidth="60dp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="取消"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip_button" />

                <TextView
                    android:id="@+id/btnDone"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:minWidth="60dp"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="确定"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_chip_button_primary" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
